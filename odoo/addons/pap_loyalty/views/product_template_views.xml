<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="product_template_form_loyalty" model="ir.ui.view">
        <field name="name">product.template.form.loyalty</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales']" position="inside">
                <separator string="Programa de Fidelización"/>
                <group>
                    <field name="loyalty_eligible"/>
                    <field name="redeemable"/>
                    <field name="loyalty_cost" invisible="not redeemable"/>
                    <field name="loyalty_ratio"/>
                </group>
            </xpath>
            <xpath expr="//div[@name='options']" position="inside">
                <span class="d-inline-block">
                    <field name="minimum_stock" class="oe_inline"/>
                    <label for="minimum_stock"/>
                </span>
            </xpath>
        </field>
    </record>

</odoo>
